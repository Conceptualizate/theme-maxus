# Ignore everything by default
/*

# Keep repo metadata/docs
!.gitignore
!README.md

# Allow wp-content tree, then re-ignore everything inside
!wp-content/
wp-content/*

# Track only the custom theme
!wp-content/themes/
wp-content/themes/*
!wp-content/themes/maxus/
!wp-content/themes/maxus/**

# Track only the custom plugin
!wp-content/plugins/
wp-content/plugins/*
!wp-content/plugins/maxus-post-types/
!wp-content/plugins/maxus-post-types/**

# Optional local noise
*.log
*.sql
.DS_Store
Thumbs.db